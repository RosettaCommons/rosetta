<ROSETTASCRIPTS>
	<SCOREFXNS>
		<ScoreFunction name="ref15" weights="ref2015"/>
	</SCOREFXNS>

	<MOVERS>
		<MakeBundle name="make" use_degrees="true"
			crick_params_file="alpha_helix" helix_length="21"
			residue_name="GLU,LEU,LEU,LYS,ALA,ILE,ALA"
			r0="6.5" omega0="-2.56" set_bondlengths="true"
			set_bondangles="true">
			<Helix delta_omega0="0"/>
			<Helix delta_omega0="120"/>
			<Helix delta_omega0="240"/>
		</MakeBundle>
		<MinMover name="min" scorefxn="ref15"
			type="lbfgs_armijo_nonmonotone" tolerance="0.01" max_iter="200">
			<MoveMap>
				<Parametric enable="true"/>
				<Chi enable="false"/>
			</MoveMap>
		</MinMover>
	</MOVERS>

	<PROTOCOLS>
		<Add mover="make"/>
		<Add mover="min"/>
	</PROTOCOLS>

	<OUTPUT scorefxn="ref15"/>
</ROSETTASCRIPTS>
